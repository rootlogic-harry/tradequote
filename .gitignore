# Dependencies
node_modules/

# Build output
dist/

# Compiled Tailwind for the PDF renderer — generated by
# `npm run build:pdf-css` (runs automatically before `vite build`).
# Lives in public/ so Vite picks it up. Not committed to keep diffs
# clean and to avoid the compiled file drifting from the source.
public/quote-tailwind.css

# Environment files (none expected, but belt-and-braces)
.env
.env.local
.env.*.local

# Editor
.DS_Store
.vscode/
*.swp

# Test coverage
coverage/

# MCP config (local)
.mcp.json

# Claude Code local settings (per-machine tool allowlist, gitignored)
.claude/settings.local.json

# Logs
npm-debug.log*

# Local Claude Code agent config (per-machine, never committed)
.claude/

# PDF-fixture private/ subdirs hold the original bug-evidence PDFs for
# each regression fixture (TRQ-178). Those are usually real customer
# renders with PII — kept locally so reviewers can re-open the source
# of the bug, but never committed. Sanitised inputs + post-fix renders
# live alongside and ARE committed; see fixture README files.
regression/pdf-fixtures/*/private/

# Local cache dirs the renderFixture.js script creates while bundling
# QuoteDocument.jsx via esbuild. Removed on success but a crashed
# render can leave one behind — never commit them.
.pdf-fixture-cache-*/

# Regression suite reports are timestamp-named and regenerated every
# run. The latest is uploaded as a CI artifact on each PR — we don't
# need them in git. Baselines (regression/baselines/*.json) ARE
# committed: they're the audit trail of "what passing looked like
# when we accepted it".
regression/reports/*.md

# Playwright smoke — HTML reports + traces are per-run artifacts,
# uploaded to CI on failure. Nothing to commit.
playwright-report/
test-results/
