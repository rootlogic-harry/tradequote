# FastQuote backup-service image.
#
# A SEPARATE Railway service runs this image on a daily cron schedule.
# Distinct from the main app image because:
#   - Needs `postgresql-client` (for pg_dump). The main app doesn't.
#   - No Chromium, no ffmpeg, no Vite build step — kept lean.
#   - Different env var surface (R2 creds, no Stripe / OAuth).
#
# Deploy:
#   - Railway project → New Service → Deploy from GitHub repo
#   - Dockerfile path: Dockerfile.backup
#   - Add cron schedule: "0 3 * * *" (03:00 UTC daily)
#   - Add env vars: DATABASE_URL (ref the main app's), R2_*,
#     optionally BACKUP_ALERT_WEBHOOK
#   - See docs/BACKUP.md for the full runbook.

FROM node:20-bullseye-slim

# postgresql-client-18 provides pg_dump matching the Railway-managed
# Postgres 18 server. Debian bullseye's default `postgresql-client`
# metapackage is v13, which pg_dump refuses to use against a v18
# server ("server version mismatch"). We pull the matching major
# from the PGDG APT repo. curl + gnupg are needed only to fetch and
# trust the PGDG signing key; we purge them after to keep the image
# lean.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      gnupg \
  && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
       | gpg --dearmor -o /usr/share/keyrings/pgdg.gpg \
  && echo "deb [signed-by=/usr/share/keyrings/pgdg.gpg] http://apt.postgresql.org/pub/repos/apt bullseye-pgdg main" \
       > /etc/apt/sources.list.d/pgdg.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends postgresql-client-18 \
  && apt-get purge -y curl gnupg \
  && apt-get autoremove -y \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Dep install first for layer caching. We need ONLY @aws-sdk/client-s3
# and @aws-sdk/lib-storage at runtime; everything else in package.json
# is for the main app. `npm ci --omit=dev` keeps the install lean.
COPY package.json package-lock.json ./
RUN npm ci --omit=dev --no-audit --no-fund

# The script. Keep the copy narrow so a stray change elsewhere doesn't
# bust the layer cache.
COPY scripts/backup-to-r2.js ./scripts/backup-to-r2.js

ENV NODE_ENV=production

# Railway invokes `startCommand` — we declare it here as the default
# so the image is self-contained for local testing too.
CMD ["node", "scripts/backup-to-r2.js"]
