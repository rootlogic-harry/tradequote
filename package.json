{
  "name": "tradequote",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --testPathIgnorePatterns='api.test.js'",
    "test:api": "node --experimental-vm-modules node_modules/.bin/jest --runInBand -- src/__tests__/api.test.js",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch --testPathIgnorePatterns='api.test.js'",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --testPathIgnorePatterns='api.test.js'"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "vite": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/src/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/utils/**/*.js"
    ]
  }
}
